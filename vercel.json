{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/jobs/poll-tenders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/jobs/process-alerts",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/jobs/(.*)",
      "headers": [
        {
          "key": "x-vercel-cron",
          "value": "true"
        }
      ]
    }
  ]
}
