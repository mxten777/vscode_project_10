{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["icn1"],
  "functions": {
    "src/app/api/jobs/poll-tenders/route.ts": {
      "regions": ["icn1"]
    }
  },
  "crons": [
    {
      "path": "/api/jobs/cron-ingest",
      "schedule": "0 0 * * 1-5"
    },
    {
      "path": "/api/jobs/cron-maintenance",
      "schedule": "0 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/jobs/(.*)",
      "headers": [
        {
          "key": "x-vercel-cron",
          "value": "true"
        }
      ]
    }
  ]
}
