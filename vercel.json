{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["icn1"],
  "crons": [
    {
      "path": "/api/jobs/poll-tenders",
      "schedule": "0 9 * * 1-5"
    },
    {
      "path": "/api/jobs/process-alerts",
      "schedule": "30 9 * * 1-5"
    }
  ],
  "headers": [
    {
      "source": "/api/jobs/(.*)",
      "headers": [
        {
          "key": "x-vercel-cron",
          "value": "true"
        }
      ]
    }
  ]
}
